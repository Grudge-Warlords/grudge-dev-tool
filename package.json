{
  "name": "grudge-dev-tool",
  "version": "0.5.4",
  "description": "Grudge Studio developer tooling — grudge-dev CLI (ONE TRUTH doctor, upload-pack) and Windows Forge tray app (object storage, Forge 3D, BlenderKit).",
  "private": true,
  "homepage": "https://grudge-warlords.github.io/grudge-dev-tool/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Grudge-Warlords/grudge-dev-tool.git"
  },
  "bugs": {
    "url": "https://github.com/Grudge-Warlords/grudge-dev-tool/issues"
  },
  "main": "dist/main/main.js",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.2",
  "author": {
    "name": "Racalvin The Pirate King",
    "email": "games@grudgestudio.org"
  },
  "license": "UNLICENSED",
  "scripts": {
    "dev": "concurrently -k -n vite,main \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch & wait-on tcp:5173 && electron .",
    "build:icons": "node scripts/build-icons.mjs",
    "prebuild": "npm run build:icons",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "package": "npm run build && electron-builder --win nsis",
    "package:ci": "npm run build && electron-builder --win nsis --publish never",
    "package:dir": "npm run build && electron-builder --dir",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "upload-pack": "tsx scripts/upload-asset-pack.ts",
    "scaffold:r3f": "node scripts/scaffold-r3f.mjs",
    "secret:import": "node scripts/import-secrets.mjs",
    "secret:set": "node scripts/set-secret.mjs",
    "secret:verify": "node scripts/verify-creds.mjs",
    "publish:manual": "node scripts/publish-manual.mjs --bump patch",
    "publish:manual:minor": "node scripts/publish-manual.mjs --bump minor",
    "publish:manual:major": "node scripts/publish-manual.mjs --bump major",
    "publish:manual:dry": "node scripts/publish-manual.mjs --bump patch --dry-run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.1",
    "@aws-sdk/s3-request-presigner": "^3.658.1",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@heyputer/puter.js": "^2.2.15",
    "@tanstack/react-query": "^5.51.1",
    "electron-log": "^5.1.7",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.2.1",
    "fflate": "^0.8.2",
    "keytar": "^7.9.0",
    "lucide-react": "^0.408.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^1.5.0",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.51.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.39",
    "sharp": "^0.33.4",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.7.0",
    "vite": "^8.0.10",
    "wait-on": "^7.2.0"
  }
}
