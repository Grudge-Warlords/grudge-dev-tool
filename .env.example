# Production environment variables consumed by the Grudge Dev Tool.
# Copy this file to `.env` (which is .gitignored) and fill in real values, OR
# export the vars in your shell. None are required at runtime — the app falls
# back to safe defaults.

# ---------------------------------------------------------------------------
# Backend (ONE TRUTH)
# ---------------------------------------------------------------------------
# v0.5+ defaults to a single fleet client host. Vercel rewrites on
# client.grudge-studio.com proxy fleet manifest, auth, objectstore JSON,
# and /api/objectstore/* upload routes — same URL the CLI and browser use.
#
# Legacy split-host installs (game-api + assets-api on separate hosts) can
# still set GRUDGE_ASSETS_API_BASE explicitly.

# Fleet client URL (auth + game-data + objectstore rewrites). Default: https://client.grudge-studio.com
GRUDGE_API_BASE=https://client.grudge-studio.com

# Railway game-data SSOT (characters, account, wallet). Prefer via client proxy in browsers.
GRUDGE_GAME_DATA_URL=https://grudge-api-production-0d46.up.railway.app

# Grudge ID gateway
GRUDGE_ID_BASE=https://id.grudge-studio.com

# Optional legacy objectstore host override. When unset, objectstore uses GRUDGE_API_BASE.
# GRUDGE_ASSETS_API_BASE=   # deprecated split-host — leave unset

# ---------------------------------------------------------------------------
# Cloudflare R2 (object storage — same names the backend's .env uses, so you
# can paste the production block and run `npm run secret:import` to ingest)
# ---------------------------------------------------------------------------
# Canonical production values:
#   bucket   = grudge-assets
#   region   = auto                       (R2 does NOT use us-east-1)
#   public   = https://assets.grudge-studio.com  (Cloudflare Worker fronting the bucket)
#   endpoint = https://<account-id>.r2.cloudflarestorage.com
#
# Stored in the Windows Credential Vault via keytar (NEVER kept in this file).
# Use `node scripts/import-secrets.mjs <file>` to ingest, or paste each into
# the Settings page.
# OBJECT_STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# OBJECT_STORAGE_BUCKET=grudge-assets
# OBJECT_STORAGE_KEY=<32-char access key id>
# OBJECT_STORAGE_SECRET=<64-char secret>
# OBJECT_STORAGE_REGION=auto
# OBJECT_STORAGE_PUBLIC_URL=https://assets.grudge-studio.com
# OBJECT_STORAGE_PUBLIC_R2_URL=https://pub-<hash>.r2.dev

# ---------------------------------------------------------------------------
# Cloudflare AI Gateway (optional — dev tool falls back to Legion hub)
# ---------------------------------------------------------------------------
# Stored in Windows Credential Vault via `npm run secret:import`.
# Without these, AI routes through https://ai.grudge-studio.com after sign-in.
# CF_AI_WORKERS_API=<workers-ai-api-token>
# CF_ACCOUNT_ID=<32-char-cloudflare-account-id>
# CF_AI_GATEWAY_ID=<your-ai-gateway-id>
# GRUDGE_AI_KEY=<fleet-bearer-for-legion-hub>
# GRUDGE_LEGION_HUB=https://ai.grudge-studio.com
# GRUDGE_GRUDA_AGENT=https://grudaagent.vercel.app

# ---------------------------------------------------------------------------
# BlenderKit (optional; only needed for the Asset Library + ingestion enrich)
# ---------------------------------------------------------------------------
# Path to an on-disk BlenderKit addon install. The app will also probe
# %APPDATA%\Blender Foundation\Blender\<ver>\extensions\user_default\blenderkit
# and ...\scripts\addons\blenderkit. Set this only if your install lives
# somewhere non-standard.
# BLENDERKIT_PATH=C:\path\to\blenderkit

# Set to any non-empty value to suppress the dev fallback path entirely.
# BLENDERKIT_NO_PINNED=1

# Personal API key from https://www.blenderkit.com/profile/  (production users
# should set this in the Settings page instead — it gets stored in Windows
# Credential Vault via keytar). The env var is read only when keytar is empty.
# BLENDERKIT_API_KEY=bk_...

# ---------------------------------------------------------------------------
# Admin gating (renderer, build-time)
# ---------------------------------------------------------------------------
# These VITE_* vars are read by src/renderer/lib/admin.ts and inlined into the
# renderer bundle at build time. They decide which signed-in Puter users see
# the admin-only routes (Upload, Forge 3D, Coder, Games, Preview, Settings).
#
# Either var (or both) may be set; matching is case-insensitive and entries
# are comma-separated. If BOTH are empty/unset, the build runs in OPEN MODE
# and every signed-in user is treated as admin — appropriate for local dev
# builds, NEVER for a public release.
#
# Admin is a UX gate, not a security boundary; the backend / Cloudflare Worker
# still enforces the real permissions on every privileged call.

# Comma-separated list of Grudge IDs (lowercased hex, the value the app shows
# under the username in the sidebar).
# VITE_ADMIN_GRUDGE_IDS=abcd1234ef...,9876fedc...

# Comma-separated list of Puter usernames (canonical production operators).
# VITE_ADMIN_USERNAMES=grudachain,molochdadev

# Comma-separated admin emails (matched case-insensitively).
# VITE_ADMIN_EMAILS=grudgedev@gmail.com,jonbemmons@gmail.com

# Set to "true" ONLY for local dev to treat all signed-in users as admin.
# VITE_OPEN_ADMIN_MODE=true

# ---------------------------------------------------------------------------
# Legion AI orchestrator + local Ollama (autonomous / vibe coding)
# ---------------------------------------------------------------------------
# Legion AI Hub (default: https://ai.grudge-studio.com)
# GRUDGE_LEGION_HUB=https://ai.grudge-studio.com

# GRUDA Agent fallback (default: https://grudaagent.vercel.app)
# GRUDGE_GRUDA_AGENT=https://grudaagent.vercel.app

# Fleet API key for Legion hub auth (D1 grudge-fleet key or JWT)
# GRUDGE_AI_KEY=

# Local Ollama (optional). Settings → AI preference: auto | ollama | cloudflare
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Workers AI model overrides
# CF_AI_DEFAULT_MODEL=@cf/meta/llama-3.1-8b-instruct
# CF_AI_VISION_MODEL=@cf/llava-hf/llava-1.5-7b-hf

# grudgedot launcher API for live GitHub Releases merge
# GRUDGEDOT_API=https://grudgedot.vercel.app

# ObjectStore catalog base
# GRUDGE_OBJECTSTORE=https://objectstore.grudge-studio.com

# Forge editor
# GRUDGE_FORGE_URL=https://forge.grudge-studio.com

# ---------------------------------------------------------------------------
# Build / publish
# ---------------------------------------------------------------------------
# GitHub token used by `electron-builder --publish always` and by `gh release
# create`. The repo's GitHub Actions runner injects this automatically as
# secrets.GITHUB_TOKEN; for local manual publishes, run `gh auth login` once
# and the gh CLI handles it.
# GH_TOKEN=ghp_...

# Optional Windows code-signing (deferred until we have an EV cert).
# CSC_LINK=base64-of-cert.pfx
# CSC_KEY_PASSWORD=...
