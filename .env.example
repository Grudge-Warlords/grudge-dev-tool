# Production environment variables consumed by the Grudge Dev Tool.
# Copy this file to `.env` (which is .gitignored) and fill in real values, OR
# export the vars in your shell. None are required at runtime — the app falls
# back to safe defaults.

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
# The canonical production backend (Grudge-Warlords/grudge-studio-backend) splits
# the HTTP surface across two services:
#   * api.grudge-studio.com         → game-api      (port 3003, MySQL-backed)
#   * assets-api.grudge-studio.com  → asset-service (port 3008, R2-backed)
# DB stack on the server is MySQL 8 + Redis 7 (the previous PostgreSQL/Drizzle
# prototype has been retired). The dev tool talks HTTP only — no direct DB
# access — and routes object-storage calls to asset-service by default.

# Override the default game-api base URL.    Default: https://api.grudge-studio.com
GRUDGE_API_BASE=https://api.grudge-studio.com

# Override the default asset-service base URL. Default: https://assets-api.grudge-studio.com
# Single-domain dev installs that proxy /api/objectstore/* through game-api can
# point this at the same value as GRUDGE_API_BASE.
GRUDGE_ASSETS_API_BASE=https://assets-api.grudge-studio.com

# ---------------------------------------------------------------------------
# Cloudflare R2 (object storage — same names the backend's .env uses, so you
# can paste the production block and run `npm run secret:import` to ingest)
# ---------------------------------------------------------------------------
# Canonical production values:
#   bucket   = grudge-assets
#   region   = auto                       (R2 does NOT use us-east-1)
#   public   = https://assets.grudge-studio.com  (Cloudflare Worker fronting the bucket)
#   endpoint = https://<account-id>.r2.cloudflarestorage.com
#
# Stored in the Windows Credential Vault via keytar (NEVER kept in this file).
# Use `node scripts/import-secrets.mjs <file>` to ingest, or paste each into
# the Settings page.
# OBJECT_STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# OBJECT_STORAGE_BUCKET=grudge-assets
# OBJECT_STORAGE_KEY=<32-char access key id>
# OBJECT_STORAGE_SECRET=<64-char secret>
# OBJECT_STORAGE_REGION=auto
# OBJECT_STORAGE_PUBLIC_URL=https://assets.grudge-studio.com
# OBJECT_STORAGE_PUBLIC_R2_URL=https://pub-<hash>.r2.dev

# ---------------------------------------------------------------------------
# BlenderKit (optional; only needed for the Asset Library + ingestion enrich)
# ---------------------------------------------------------------------------
# Path to an on-disk BlenderKit addon install. The app will also probe
# %APPDATA%\Blender Foundation\Blender\<ver>\extensions\user_default\blenderkit
# and ...\scripts\addons\blenderkit. Set this only if your install lives
# somewhere non-standard.
# BLENDERKIT_PATH=C:\path\to\blenderkit

# Set to any non-empty value to suppress the dev fallback path entirely.
# BLENDERKIT_NO_PINNED=1

# Personal API key from https://www.blenderkit.com/profile/  (production users
# should set this in the Settings page instead — it gets stored in Windows
# Credential Vault via keytar). The env var is read only when keytar is empty.
# BLENDERKIT_API_KEY=bk_...

# ---------------------------------------------------------------------------
# Build / publish
# ---------------------------------------------------------------------------
# GitHub token used by `electron-builder --publish always` and by `gh release
# create`. The repo's GitHub Actions runner injects this automatically as
# secrets.GITHUB_TOKEN; for local manual publishes, run `gh auth login` once
# and the gh CLI handles it.
# GH_TOKEN=ghp_...

# Optional Windows code-signing (deferred until we have an EV cert).
# CSC_LINK=base64-of-cert.pfx
# CSC_KEY_PASSWORD=...
